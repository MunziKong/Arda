  m_Script: {fileID: 11500000, guid: c0ab0e00876e1694b90726e8f8183999, type: 3}
  m_Name: MQ_4
  m_EditorClassIdentifier: Assembly-CSharp::QuestDefinition
  questId: 4
  questName: "4. \uC0C1\uC810\uACFC \uAC15\uD654"
  startDialogues:
  - "\uC774\uC81C \uB098\uD55C\uD14C \uB9D0\uC744 \uAC78\uBA74 \uC0C1\uC810\uC774\uB791
    \uAC15\uD654 \uAE30\uB2A5\uC744 \uC4F8 \uC218 \uC788\uC5B4."
  - "\uC0C1\uC810\uC5D0\uC11C\uB294 \uC5EC\uB7EC \uC544\uC774\uD15C\uC744 \uAD6C\uB9E4\uD560
    \uC218 \uC788\uACE0, \uC2A4\uD0AC\uBD81\uC744 \uC0AC\uBA74 \uC0C8\uB85C\uC6B4
    \uC2A4\uD0AC\uB3C4 \uD574\uAE08\uD560 \uC218 \uC788\uC5B4."
  - "\uAC15\uD654\uB294 \uB9D0 \uADF8\uB300\uB85C \uB124 \uBB34\uAE30\uB97C \uB354
    \uAC15\uD558\uAC8C \uB9CC\uB4DC\uB294 \uAC70\uC57C. "
  - "\uBB38\uC81C\uB294 \uADF8\uB0E5 \uB418\uB294 \uAC8C \uC544\uB2C8\uB77C\uB294
    \uAC70\uC57C. \uAC15\uD654 \uC7AC\uB8CC\uB791 \uACE8\uB4DC\uAC00 \uD544\uC694\uD55C\uB370,
    \uB458 \uB2E4 \uBAAC\uC2A4\uD130\uB97C \uAD6C\uC870\uD558\uAC70\uB098 \uC778\uAC04\uB4E4\uC744
    \uCC98\uCE58\uD558\uBA74 \uC5BB\uC744 \uC218 \uC788\uC5B4."
  - "\uC5B4\uCC28\uD53C \uBAAC\uC2A4\uD130\uB4E4\uC744 \uAD6C\uC870\uD558\uB2E4 \uBCF4\uBA74
    \uB9C8\uC8FC\uCE60 \uB188\uB4E4\uC774\uB2C8\uAE4C, \uCC98\uCE58\uD558\uB294 \uAE40\uC5D0
    \uC7AC\uB8CC\uB3C4 \uC880 \uBAA8\uC544\uBD10."
  - "\uC77C\uB2E8 \uBB34\uAE30\uB97C \uB450 \uB2E8\uACC4 \uC815\uB3C4 \uAC15\uD654\uD574\uBD10."
  inProgressDialogues:
  - "\uC544\uC9C1 \uAC15\uD654 \uB2E8\uACC4\uAC00 \uBD80\uC871\uD55C\uB370?"
  - "\uC7AC\uB8CC\uAC00 \uC5C6\uC73C\uBA74 \uB098\uAC00\uC11C \uBAAC\uC2A4\uD130\uB97C
    \uAD6C\uC870\uD558\uAC70\uB098 \uC778\uAC04\uB4E4\uC744 \uC7A1\uC544\uBD10."
  - "\uAC15\uD654\uC5D0 \uC2E4\uD328\uD574\uB3C4 \uB108\uBB34 \uC2E4\uB9DD\uD558\uC9C0
    \uB9C8. \uD558\uB2E4 \uBCF4\uBA74 \uC5B8\uC820\uAC00\uB294 \uC131\uACF5\uD558\uAC8C
    \uB418\uC5B4 \uC788\uC5B4."
  conditions:
  - {fileID: 11400000, guid: 2a59780f7e9660c44aca0be2d4f1ae84, type: 2}
  completionMode: 1
  completeDialogues:
  - "\uC0DD\uAC01\uBCF4\uB2E4 \uC190\uC774 \uBE60\uB974\uB124. \uADF8 \uC815\uB3C4\uBA74
    \uC774\uC81C \uC880 \uC4F8 \uB9CC\uD558\uACA0\uC5B4."
  - "\uC55E\uC73C\uB85C\uB3C4 \uAFB8\uC900\uD788 \uAC15\uD654\uD558\uACE0 \uC131\uC7A5\uD574.
    \uAC15\uD574\uC9C8\uC218\uB85D \uAD6C\uC870\uB3C4 \uC218\uC6D4\uD574\uC9C8 \uAC70\uACE0,
    \uC778\uAC04\uB4E4 \uC0C1\uB300\uD558\uB294 \uAC83\uB3C4 \uB35C \uC704\uD5D8\uD574\uC9C8
    \uD14C\uB2C8\uAE4C."
  acceptAtPortalOnly: 0
  suppressNamePopup: 0
  rewards:
  - item: {fileID: 11400000, guid: 898de5fbf11a7084b9bd9155477716c4, type: 2}
    quantity: 5000
  - item: {fileID: 11400000, guid: c7f841a41e3a5f14786b1002824c9623, type: 2}
    quantity: 3
