  m_Script: {fileID: 11500000, guid: c0ab0e00876e1694b90726e8f8183999, type: 3}
  m_Name: MQ_1
  m_EditorClassIdentifier: Assembly-CSharp::QuestDefinition
  questId: 1
  questName: "1. \uB208\uC744 \uB728\uB2E4 "
  startDialogues:
  - "\uC598. \uC5B4\uC11C \uC77C\uC5B4\uB098."
  - "\uBC29\uAE08 \uB208 \uB5B4\uC73C\uB2C8 \uC815\uC2E0\uC5C6\uACA0\uC9C0\uB9CC,
    \uC774\uAC83\uC800\uAC83 \uB458\uB7EC\uBCFC \uC2DC\uAC04 \uC5C6\uC5B4. \uD55C\uC2DC\uAC00
    \uAE09\uD55C \uC0C1\uD669\uC774\uC57C."
  - "\uAC04\uB2E8\uD558\uAC8C \uC124\uBA85\uD560 \uD14C\uB2C8\uAE4C \uC798 \uB4E4\uC5B4."
  - "\uC5EC\uAE30\uB294 \uB0B4\uAC00 \uCC3D\uC870\uD55C \uC138\uACC4, \uC544\uB974\uB2E4\uC57C.
    \uC628 \uC6B0\uC8FC\uC758 \uBAAC\uC2A4\uD130\uB4E4\uC774 \uC640\uC11C \uBCF4\uAE08\uC790\uB9AC\uB97C
    \uB9CC\uB4E4\uACE0 \uC26C\uC5B4\uAC00\uB294 \uD3C9\uD654\uB85C\uC6B4 \uC138\uACC4...
    \uC600\uC5C8\uC9C0."
  - "\uCD5C\uADFC\uC5D0 \uC544\uB974\uB2E4\uC758 \uC790\uC6D0\uC744 \uBC1C\uACAC\uD558\uACE0
    \uD0D0\uB0B4\uB294 \uC778\uAC04\uB4E4\uC774 \uB118\uC5B4\uC624\uAE30 \uC2DC\uC791\uD588\uC5B4.
    \uD3C9\uD654\uB86D\uAC8C \uC9C0\uB0B4\uB358 \uBAAC\uC2A4\uD130\uB4E4\uC744 \uBB34\uBD84\uBCC4\uD558\uAC8C
    \uC0AC\uB0E5\uD558\uACE0, \uB0A9\uCE58\uD558\uACE0 \uC788\uC5B4."
  - "\uCC98\uC74C\uC5D4 \uB0B4\uAC00 \uC9C1\uC811 \uB098\uC11C\uC11C \uB9C9\uC558\uC5B4.
    \uADF8\uB7F0\uB370 \uC624\uB294 \uB188\uB4E4 \uC218\uAC00 \uB108\uBB34 \uB9CE\uC544.
    \uB098 \uD63C\uC790\uB860 \uD55C\uACC4\uAC00 \uC788\uB354\uB77C\uACE0."
  - "\uADF8\uB798\uC11C \uB9CC\uB4E0 \uAC8C \uB108\uC57C. \uC9C0\uAE08\uBD80\uD130
    \uB124\uAC00 \uD574\uC57C \uD560 \uC77C\uC744 \uC54C\uB824\uC904\uAC8C. \uB098\uB97C
    \uB530\uB77C\uC640."
  inProgressDialogues: []
  conditions:
  - {fileID: 11400000, guid: 2beb6f11bc0dbc14f9c0d5122baca2c1, type: 2}
  completionMode: 0
  completeDialogues:
  - "\uBA3C\uC800, \uC774\uACF3\uC740 \uB0B4\uAC00 \uC778\uAC04\uB4E4\uC758 \uB208\uC744
    \uD53C\uD574 \uB108\uC640 \uBAAC\uC2A4\uD130\uB4E4\uC774 \uC9C0\uB0BC \uC218
    \uC788\uAC8C \uB9CC\uB4E0 \uACF5\uAC04\uC774\uC57C."
  - "\uB124\uAC00 \uD560 \uC77C\uC740 \uB2E8\uC21C\uD574. \uC774 \uACF5\uAC04\uC5D0
    \uBA38\uBB3C\uBA74\uC11C \uBC16\uC73C\uB85C \uB098\uAC00 \uC704\uD5D8\uC5D0 \uCC98\uD55C
    \uBAAC\uC2A4\uD130\uB4E4\uC744 \uCC3E\uC544 \uAD6C\uD574\uC8FC\uB294 \uAC70\uC57C."
  - "\uAD6C\uC870\uD558\uB2E4 \uBCF4\uBA74 \uC778\uAC04\uB4E4\uB3C4 \uB9CE\uC774
    \uB9C8\uC8FC\uCE58\uAC8C \uB420 \uD150\uB370, \uC804\uD22C\uAC00 \uD544\uC694\uD558\uBA74
    \uC2F8\uC6B0\uACE0 \uB3C4\uB9DD\uCCD0\uC57C \uD558\uBA74 \uB3C4\uB9DD\uCCD0.
    \uD310\uB2E8\uC740 \uB124\uAC00 \uD574."
  - "\uC6B0\uC120 \uB108\uC5D0\uAC8C \uB3C4\uC6C0\uC774 \uB420 \uB9CC\uD55C \uAC78
    \uC904\uAC8C. \uB098\uD55C\uD14C \uB2E4\uC2DC \uD55C\uBC88 \uB9D0\uC744 \uAC78\uC5B4\uBD10."
  acceptAtPortalOnly: 0
  suppressNamePopup: 1
  rewards:
  - item: {fileID: 11400000, guid: 898de5fbf11a7084b9bd9155477716c4, type: 2}
    quantity: 1000
  nextQuest: {fileID: 11400000, guid: 968671231f383ad429dfb975b1d2a1ef, type: 2}
