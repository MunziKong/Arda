  m_Script: {fileID: 11500000, guid: c0ab0e00876e1694b90726e8f8183999, type: 3}
  m_Name: MQ_2
  m_EditorClassIdentifier: Assembly-CSharp::QuestDefinition
  questId: 2
  questName: "2. \uCCAB \uBC88\uC9F8 \uC900\uBE44"
  startDialogues:
  - "\uC790, \uC774\uAC83\uBD80\uD130 \uBC1B\uC544."
  - "\uBAAC\uC2A4\uD130 \uAD6C\uC870 \uD0A4\uD2B8\uC57C. \uC774\uAC78\uB85C \uC704\uD5D8\uC5D0
    \uCC98\uD55C \uCE5C\uAD6C\uB4E4\uC744 \uAD6C\uC870\uD560 \uC218 \uC788\uC5B4."
  - "\uC0AC\uC6A9\uBC95\uC740 \uAC04\uB2E8\uD574. \uAC00\uAE4C\uC774 \uB2E4\uAC00\uAC04
    \uC0C1\uD0DC\uC5D0\uC11C E\uB97C 3\uCD08 \uB3D9\uC548 \uAFB9 \uB204\uB974\uBA74
    \uB3FC"
  - "\uB2E8, \uD56D\uC0C1 \uC131\uACF5\uD558\uB294 \uAC74 \uC544\uB2C8\uC57C. \uBAAC\uC2A4\uD130\uAC00
    \uB180\uB77C\uC11C \uBAA8\uC2B5\uC744 \uAC10\uCDB0\uBC84\uB9B4 \uC218\uB3C4 \uC788\uAC70\uB4E0.
    \uADF8\uB798\uB3C4 \uC2DC\uAC04\uC774 \uC9C0\uB098\uBA74 \uB2E4\uC2DC \uB098\uD0C0\uB0A0
    \uD14C\uB2C8\uAE4C \uB2F9\uD669\uD558\uC9C0 \uB9C8."
  - "\uB098\uAC00\uAE30 \uC804\uC5D0 \uD55C \uAC00\uC9C0 \uB354 \uC904\uAC8C. \uC800\uAE30
    \uC606\uC5D0 \uBCF4\uC774\uB294 \uC81C\uB2E8\uC744 \uB20C\uB7EC\uBD10."
  inProgressDialogues:
  - "\uB098 \uB9D0\uACE0 \uC81C\uB2E8\uC744 \uB20C\uB7EC\uBD10. "
  conditions:
  - {fileID: 11400000, guid: 5d59676f7d3d31a40a59c3f62438ffac, type: 2}
  completionMode: 0
  completeDialogues:
  - "\uC5EC\uAE30\uC11C\uB294 \uBB34\uAE30\uC640 \uC2A4\uD0AC\uC744 \uC120\uD0DD\uD560
    \uC218 \uC788\uC5B4."
  - "\uBE48\uC190\uC73C\uB85C \uB0B4\uBCF4\uB0BC \uC815\uB3C4\uB85C \uC57C\uBC15\uD558\uC9C4
    \uC54A\uAC70\uB4E0."
  - "\uC9C0\uAE08 \uB2F9\uC7A5 \uC4F8 \uC218 \uC788\uB294 \uC2A4\uD0AC\uC740 \uD558\uB098\uC9C0\uB9CC,
    \uC55E\uC73C\uB85C \uB354 \uC5BB\uAC8C \uB420 \uAC70\uC57C. \uC5BB\uC740 \uC2A4\uD0AC\uB4E4\uC740
    \uC6D0\uD558\uB294 \uB300\uB85C \uC870\uD569\uD574\uC11C \uC4F0\uBA74 \uB3FC.
    \uBB34\uAE30\uB294 \uC790\uC720\uB86D\uAC8C \uACE8\uB77C."
  - "\uC774\uC81C \uC9C4\uC9DC \uB098\uAC08 \uC900\uBE44\uAC00 \uB41C \uAC83 \uAC19\uB124.
    \uBB34\uAE30\uC640 \uC2A4\uD0AC\uC744 \uC7A5\uCC29\uD558\uACE0 \uC800\uAE30 \uBCF4\uC774\uB294
    \uD30C\uB780 \uD3EC\uD0C8\uB85C \uC640."
  acceptAtPortalOnly: 0
  suppressNamePopup: 0
  rewards:
  - item: {fileID: 11400000, guid: 898de5fbf11a7084b9bd9155477716c4, type: 2}
