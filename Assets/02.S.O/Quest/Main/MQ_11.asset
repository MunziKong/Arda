  m_Name: MQ_11
  m_EditorClassIdentifier: Assembly-CSharp::QuestDefinition
  questId: 11
  questName: "11. \uCD5C\uC885 \uACB0\uC804 "
  startDialogues:
  - "...\uB4DC\uB514\uC5B4 \uC5EC\uAE30\uAE4C\uC9C0 \uC654\uB124."
  - "\uC778\uAC04\uB4E4\uC774 \uBCF8\uACA9\uC801\uC73C\uB85C \uBAB0\uB824\uC624\uACE0
    \uC788\uC5B4. \uC774\uBC88\uC774 \uB9C8\uC9C0\uB9C9\uC774 \uB420 \uAC70\uC57C."
  - "\uAE30\uC0AC, \uB4DC\uB8E8\uC774\uB4DC, \uB3C4\uC801, \uAD81\uC218. \uC804\uBD80
    \uC5F4 \uBA85\uC529 \uCC98\uCE58\uD574."
  - "\uC27D\uC9C0 \uC54A\uC744 \uAC70\uC57C. \uD558\uC9C0\uB9CC \uB108\uB77C\uBA74
    \uD560 \uC218 \uC788\uC744 \uAC70\uB77C\uACE0 \uC0DD\uAC01\uD574."
  inProgressDialogues:
  - "\uC22B\uC790\uAC00 \uB9CE\uC544 \uBCF4\uC774\uACA0\uC9C0\uB9CC, \uC9C0\uAE08
    \uB124 \uC2E4\uB825\uC774\uBA74 \uCDA9\uBD84\uD788 \uD574\uB0BC \uC218 \uC788\uC5B4."
  - "\uD798\uB4E4\uBA74 \uC7A0\uAE50 \uC26C\uC5C8\uB2E4\uAC00 \uB2E4\uC2DC \uAC00.
    \uC11C\uB450\uB97C \uD544\uC694 \uC5C6\uC5B4."
  conditions:
  - {fileID: 11400000, guid: 7f24023470c9155448070b7d8c291d41, type: 2}
  - {fileID: 11400000, guid: 3fb7304621f4059428bf474dad1fd6b1, type: 2}
  - {fileID: 11400000, guid: e1df3c530a6255d4fb0ad3fa147540d7, type: 2}
  - {fileID: 11400000, guid: f190b79ab0232fc48ab29982819b8efe, type: 2}
  completionMode: 1
  completeDialogues:
  - "...\uB05D\uB0C8\uAD6C\uB098."
  - "\uC0DD\uAC01\uBCF4\uB2E4 \uBE68\uB790\uC5B4. \uC544\uB2C8, \uC5B4\uCA4C\uBA74
    \uB0B4\uAC00 \uB108\uB97C \uB108\uBB34 \uB2A6\uAC8C \uBBFF\uC5B4\uC900 \uAC78\uC9C0\uB3C4
    \uBAA8\uB974\uACA0\uB2E4."
  - "\uADF8\uB3D9\uC548 \uC815\uB9D0 \uACE0\uC0DD\uD588\uC5B4. \uB124\uAC00 \uC5C6\uC5C8\uC73C\uBA74
    \uC5EC\uAE30\uAE4C\uC9C0 \uBABB \uC654\uC744 \uAC70\uC57C. \uACE0\uB9D9\uB2E4\uB294
    \uB9D0, \uC9C4\uC2EC\uC73C\uB85C \uD558\uACE0 \uC2F6\uC5C8\uC5B4."
  - "...\uC774\uC81C\uB294 \uB108\uD55C\uD14C \uC9C4\uC2E4\uC744 \uB9D0\uD574\uC904
    \uB54C\uAC00 \uB41C \uAC83 \uAC19\uC544."
  acceptAtPortalOnly: 0
  suppressNamePopup: 0
