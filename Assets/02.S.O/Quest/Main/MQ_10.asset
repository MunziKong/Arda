  questId: 10
  questName: "10. \uADF9\uD55C\uAE4C\uC9C0"
  startDialogues:
  - "\uC9C0\uAE08\uAE4C\uC9C0 \uAC15\uD654\uB294 \uADF8\uB0E5 \uB9DB\uBCF4\uAE30\uC600\uB2E4\uACE0
    \uC0DD\uAC01\uD574."
  - "\uBB34\uAE30\uB294 5\uB2E8\uACC4\uAE4C\uC9C0 \uAC15\uD654\uD560 \uC218 \uC788\uC5B4.
    \uADF8\uAC8C \uC9C0\uAE08 \uAE30\uC900\uC73C\uB85C\uB294 \uCD5C\uB300\uCE58\uC57C."
  - "\uC7AC\uB8CC\uB3C4 \uB354 \uB9CE\uC774 \uB4E4\uACE0, \uC2E4\uD328\uD560 \uD655\uB960\uB3C4
    \uADF8\uB9CC\uD07C \uB192\uC544\uC9C0\uACA0\uC9C0. \uADF8\uB798\uB3C4 \uD574\uBCFC
    \uB9CC\uD55C \uAC00\uCE58\uB294 \uC788\uC5B4."
  - "\uAC00\uC11C \uB124 \uBB34\uAE30, 5\uB2E8\uACC4\uAE4C\uC9C0 \uAC15\uD654\uD574\uBD10."
  inProgressDialogues:
  - "\uAC15\uD654 \uB2E8\uACC4\uAC00 \uC62C\uB77C\uAC08\uC218\uB85D \uC2E4\uD328\uD560
    \uAC00\uB2A5\uC131\uB3C4 \uCEE4\uC838. \uC7AC\uB8CC \uC544\uAE5D\uB2E4\uACE0
    \uB108\uBB34 \uC18D\uC0C1\uD574\uD558\uC9C0 \uB9C8."
  - "\uBAAC\uC2A4\uD130\uB97C \uAD6C\uC870\uD558\uAC70\uB098 \uC778\uAC04\uB4E4 \uCC98\uCE58\uD558\uBA74\uC11C
    \uCC28\uADFC\uCC28\uADFC \uBAA8\uC73C\uBA74 \uB3FC. \uAE09\uD560 \uAC70 \uC5C6\uC5B4."
  conditions:
  - {fileID: 11400000, guid: 3ba3833c320f7974994ea224273b913b, type: 2}
  completionMode: 1
  completeDialogues:
  - "5\uB2E8\uACC4.. \uB9CC\uB4E4\uC5C8\uAD6C\uB098.."
  - "\uC194\uC9C1\uD788 \uB9D0\uD558\uBA74 \uC880 \uB180\uB790\uC5B4. \uADF8 \uC815\uB3C4
    \uC6B4\uC774\uBA74 \uC5B4\uB514 \uAC00\uC11C\uB3C4 \uC548 \uC8FD\uACE0 \uC0B4\uACA0\uB2E4."
  - "...\uC774\uC81C \uC2AC\uC2AC \uB54C\uAC00 \uB41C \uAC83 \uAC19\uB124."
  - "\uB124\uAC00 \uC5EC\uAE30 \uCC98\uC74C \uC654\uC744 \uB54C\uB791 \uBE44\uAD50\uD558\uBA74
    \uB9CE\uC774 \uB2EC\uB77C\uC84C\uC5B4. \uADF8 \uC815\uB3C4 \uBB34\uAE30, \uADF8
    \uC815\uB3C4 \uC2E4\uB825\uC774\uBA74 \uB354 \uC774\uC0C1 \uBBF8\uB904\uB458
    \uC774\uC720\uAC00 \uC5C6\uACA0\uC9C0."
